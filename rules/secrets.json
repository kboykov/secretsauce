[
  {
    "id": "aws_access_key_id",
    "name": "AWS Access Key ID",
    "regex": "(A3T[A-Z0-9]|AKIA|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}",
    "severity": "critical",
    "notes": "Highly specific prefix, very low FP rate"
  },
  {
    "id": "aws_secret_access_key",
    "name": "AWS Secret Access Key",
    "regex": "(?i)(?:aws[_\\-\\s]*(?:secret|secret_access_key|secret_key)|secret_access_key)[\\s]*[:=][\\s]*['\"]?([A-Za-z0-9/+]{40})['\"]?",
    "severity": "critical"
  },
  {
    "id": "aws_mws_auth_token",
    "name": "Amazon MWS Auth Token",
    "regex": "amzn\\.mws\\.[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}",
    "severity": "critical"
  },
  {
    "id": "slack_bot_token",
    "name": "Slack Bot/User Token",
    "regex": "xox[baprs]-(?:[0-9]{10,13}-){1,3}[a-zA-Z0-9]{24,34}",
    "severity": "high"
  },
  {
    "id": "slack_webhook",
    "name": "Slack Incoming Webhook URL",
    "regex": "https://hooks\\.slack\\.com/services/T[A-Z0-9]{8,10}/B[A-Z0-9]{8,10}/[a-zA-Z0-9]{20,30}",
    "severity": "high"
  },
  {
    "id": "rsa_private_key",
    "name": "RSA Private Key",
    "regex": "-----BEGIN RSA PRIVATE KEY-----",
    "severity": "critical"
  },
  {
    "id": "dsa_private_key",
    "name": "DSA Private Key",
    "regex": "-----BEGIN DSA PRIVATE KEY-----",
    "severity": "critical"
  },
  {
    "id": "ec_private_key",
    "name": "EC Private Key",
    "regex": "-----BEGIN EC PRIVATE KEY-----",
    "severity": "critical"
  },
  {
    "id": "openssh_private_key",
    "name": "OpenSSH Private Key",
    "regex": "-----BEGIN OPENSSH PRIVATE KEY-----",
    "severity": "critical"
  },
  {
    "id": "pgp_private_key",
    "name": "PGP Private Key Block",
    "regex": "-----BEGIN PGP PRIVATE KEY BLOCK-----",
    "severity": "critical"
  },
  {
    "id": "github_classic_pat",
    "name": "GitHub Classic Personal Access Token",
    "regex": "ghp_[A-Za-z0-9]{36}",
    "severity": "critical"
  },
  {
    "id": "github_oauth_token",
    "name": "GitHub OAuth Token",
    "regex": "gho_[A-Za-z0-9]{36}",
    "severity": "critical"
  },
  {
    "id": "github_actions_token",
    "name": "GitHub Actions Token",
    "regex": "ghs_[A-Za-z0-9]{36}",
    "severity": "critical"
  },
  {
    "id": "github_refresh_token",
    "name": "GitHub Refresh Token",
    "regex": "ghr_[A-Za-z0-9]{76}",
    "severity": "critical"
  },
  {
    "id": "github_fine_grained",
    "name": "GitHub Fine-Grained PAT",
    "regex": "github_pat_[A-Za-z0-9]{22}_[A-Za-z0-9]{59}",
    "severity": "critical"
  },
  {
    "id": "gitlab_token",
    "name": "GitLab Personal Access Token",
    "regex": "glpat-[a-zA-Z0-9_\\-]{20}",
    "severity": "critical"
  },
  {
    "id": "google_api_key",
    "name": "Google API Key",
    "regex": "AIza[0-9A-Za-z\\-_]{35}",
    "severity": "high"
  },
  {
    "id": "google_oauth_token",
    "name": "Google OAuth Access Token",
    "regex": "ya29\\.[0-9A-Za-z\\-_]{60,200}",
    "severity": "high"
  },
  {
    "id": "google_oauth_client_secret",
    "name": "Google OAuth Client Secret",
    "regex": "GOCSPX-[a-zA-Z0-9_\\-]{28}",
    "severity": "critical"
  },
  {
    "id": "google_service_account",
    "name": "Google Service Account Key (JSON)",
    "regex": "\"type\"\\s*:\\s*\"service_account\"",
    "severity": "critical"
  },
  {
    "id": "facebook_access_token",
    "name": "Facebook Access Token",
    "regex": "EAACEdEose0cBA[0-9A-Za-z]+",
    "severity": "high"
  },
  {
    "id": "twitter_bearer_token",
    "name": "Twitter/X Bearer Token",
    "regex": "AAAAAAAAAAAAAAAAAAAAAA[A-Za-z0-9%]{30,}",
    "severity": "high"
  },
  {
    "id": "sendgrid_api_key",
    "name": "SendGrid API Key",
    "regex": "SG\\.[a-zA-Z0-9_\\-]{22}\\.[a-zA-Z0-9_\\-]{43}",
    "severity": "critical"
  },
  {
    "id": "stripe_live_secret",
    "name": "Stripe Live Secret Key",
    "regex": "sk_live_[0-9a-zA-Z]{24,}",
    "severity": "critical"
  },
  {
    "id": "stripe_restricted_key",
    "name": "Stripe Restricted Key",
    "regex": "rk_live_[0-9a-zA-Z]{24,}",
    "severity": "critical"
  },
  {
    "id": "stripe_publishable_key",
    "name": "Stripe Publishable Key (client-side)",
    "regex": "pk_live_[0-9a-zA-Z]{24,}",
    "severity": "low"
  },
  {
    "id": "square_access_token",
    "name": "Square Access Token",
    "regex": "sqOatp-[0-9A-Za-z\\-_]{22}",
    "severity": "critical"
  },
  {
    "id": "square_oauth_secret",
    "name": "Square OAuth Client Secret",
    "regex": "sq0csp-[0-9A-Za-z\\-_]{43}",
    "severity": "critical"
  },
  {
    "id": "paypal_braintree",
    "name": "PayPal Braintree Access Token",
    "regex": "access_token\\$production\\$[0-9a-z]{16}\\$[0-9a-f]{32}",
    "severity": "critical"
  },
  {
    "id": "telegram_bot_token",
    "name": "Telegram Bot API Token",
    "regex": "[0-9]{8,10}:AA[0-9A-Za-z\\-_]{33}",
    "severity": "high"
  },
  {
    "id": "twilio_api_key",
    "name": "Twilio API Key SID",
    "regex": "SK[0-9a-fA-F]{32}",
    "severity": "high"
  },
  {
    "id": "twilio_auth_token",
    "name": "Twilio Auth Token",
    "regex": "(?i)(?:twilio).{0,40}['\"]([a-f0-9]{32})['\"]",
    "severity": "high"
  },
  {
    "id": "jwt_token",
    "name": "JSON Web Token (JWT)",
    "regex": "eyJ[A-Za-z0-9_\\-]{20,}\\.[A-Za-z0-9_\\-]{20,}\\.[A-Za-z0-9_\\-]{20,}",
    "severity": "high"
  },
  {
    "id": "password_in_url",
    "name": "Credentials in URL",
    "regex": "(?:https?|ftp|jdbc|mongodb|mysql|postgres)://[^/\\s:@]{3,50}:[^/\\s:@]{4,100}@[a-zA-Z0-9.\\-]{4,}",
    "severity": "critical"
  },
  {
    "id": "mongodb_conn_string",
    "name": "MongoDB Connection String",
    "regex": "mongodb(?:\\+srv)?://[a-zA-Z0-9_\\-]{2,}:[^@\\s'\"]{4,}@[a-zA-Z0-9._\\-]{4,}",
    "severity": "critical"
  },
  {
    "id": "mysql_conn_string",
    "name": "MySQL Connection String",
    "regex": "mysql://[a-zA-Z0-9_\\-]{2,}:[^@\\s'\"]{4,}@[a-zA-Z0-9._\\-]{4,}",
    "severity": "critical"
  },
  {
    "id": "postgresql_conn_string",
    "name": "PostgreSQL Connection String",
    "regex": "postgres(?:ql)?://[a-zA-Z0-9_\\-]{2,}:[^@\\s'\"]{4,}@[a-zA-Z0-9._\\-]{4,}",
    "severity": "critical"
  },
  {
    "id": "redis_conn_string",
    "name": "Redis Connection URL (with password)",
    "regex": "redis(?:s)?://[^:@\\s]{2,}:[^@\\s'\"]{4,}@[a-zA-Z0-9._\\-]{4,}",
    "severity": "critical"
  },
  {
    "id": "azure_conn_string",
    "name": "Azure Storage Connection String",
    "regex": "DefaultEndpointsProtocol=https?;AccountName=[^;]{3,};AccountKey=[A-Za-z0-9+/=]{60,}",
    "severity": "critical"
  },
  {
    "id": "azure_sas_token",
    "name": "Azure SAS Token",
    "regex": "sv=20[0-9]{2}-[0-9]{2}-[0-9]{2}&s[a-z]=.{6,}&sig=[A-Za-z0-9%+/=]{40,}",
    "severity": "critical"
  },
  {
    "id": "npm_auth_token",
    "name": "NPM Publish Token",
    "regex": "npm_[a-zA-Z0-9]{36}",
    "severity": "high"
  },
  {
    "id": "digitalocean_token",
    "name": "DigitalOcean Personal Access Token",
    "regex": "dop_v1_[a-f0-9]{64}",
    "severity": "critical"
  },
  {
    "id": "shopify_access_token",
    "name": "Shopify Admin Access Token",
    "regex": "shpat_[a-fA-F0-9]{32}",
    "severity": "critical"
  },
  {
    "id": "shopify_shared_secret",
    "name": "Shopify Shared Secret",
    "regex": "shpss_[a-fA-F0-9]{32}",
    "severity": "critical"
  },
  {
    "id": "shopify_custom_app",
    "name": "Shopify Custom App Token",
    "regex": "shpca_[a-fA-F0-9]{32}",
    "severity": "critical"
  },
  {
    "id": "cloudinary_url",
    "name": "Cloudinary API Credentials",
    "regex": "cloudinary://[0-9]{6,}:[a-zA-Z0-9_\\-]{20,}@[a-zA-Z0-9]{2,}",
    "severity": "high"
  },
  {
    "id": "firebase_server_key",
    "name": "Firebase Cloud Messaging Server Key",
    "regex": "AAAA[a-zA-Z0-9_\\-]{7}:[a-zA-Z0-9_\\-]{140}",
    "severity": "high"
  },
  {
    "id": "mailchimp_api_key",
    "name": "Mailchimp API Key",
    "regex": "[0-9a-f]{32}-us[0-9]{1,2}\\b",
    "severity": "high"
  },
  {
    "id": "mailgun_api_key",
    "name": "Mailgun API Key",
    "regex": "key-[0-9a-zA-Z]{32}",
    "severity": "high"
  },
  {
    "id": "mapbox_token",
    "name": "Mapbox Public/Secret Token",
    "regex": "(?:pk|sk)\\.eyJ1IjoiJ[a-zA-Z0-9_\\-]{30,}\\.[a-zA-Z0-9_\\-]{30,}",
    "severity": "medium"
  },
  {
    "id": "vault_token",
    "name": "HashiCorp Vault Token",
    "regex": "\\bhvs\\.[A-Za-z0-9_\\-]{24,}",
    "severity": "critical"
  },
  {
    "id": "heroku_api_key",
    "name": "Heroku API Key",
    "regex": "(?i)heroku(?:.{0,30})['\"]([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12})['\"]",
    "severity": "critical"
  },
  {
    "id": "algolia_api_key",
    "name": "Algolia API Key (with context)",
    "regex": "(?i)algolia.{0,40}['\"]([a-zA-Z0-9]{32})['\"]",
    "severity": "high"
  },
  {
    "id": "cloudflare_api_key",
    "name": "Cloudflare API Key (with context)",
    "regex": "(?i)cloudflare.{0,40}['\"]([a-f0-9]{37})['\"]",
    "severity": "high"
  },
  {
    "id": "generic_api_key",
    "name": "Generic API Key (contextual)",
    "regex": "(?i)(?:^|[\\s,;{])(?:api[_\\-]?key|apikey)\\s*[:=]\\s*['\"]([a-zA-Z0-9_\\-]{32,64})['\"]",
    "severity": "medium"
  },
  {
    "id": "generic_client_secret",
    "name": "Generic Client Secret (contextual)",
    "regex": "(?i)(?:client[_\\-]?secret|app[_\\-]?secret|consumer[_\\-]?secret)\\s*[:=]\\s*['\"]([a-zA-Z0-9_\\-\\.]{20,64})['\"]",
    "severity": "high"
  },
  {
    "id": "generic_access_token",
    "name": "Generic Access Token (contextual)",
    "regex": "(?i)(?:access[_\\-]?token|auth[_\\-]?token)\\s*[:=]\\s*['\"]([a-zA-Z0-9_\\-\\.=+/]{32,})['\"]",
    "severity": "high"
  },
  {
    "id": "bearer_authorization",
    "name": "Bearer Token in Authorization Header",
    "regex": "(?i)['\"]?Authorization['\"]?\\s*[:=]\\s*['\"]?Bearer\\s+([a-zA-Z0-9_\\-\\.=+/]{30,})['\"]?",
    "severity": "high"
  },
  {
    "id": "basic_authorization",
    "name": "Basic Auth in Authorization Header",
    "regex": "(?i)['\"]?Authorization['\"]?\\s*[:=]\\s*['\"]?Basic\\s+([a-zA-Z0-9+/]{30,}={0,2})['\"]?",
    "severity": "high"
  },
  {
    "id": "private_key_assignment",
    "name": "Private Key Assignment",
    "regex": "(?i)(?:private[_\\-]?key|privatekey)\\s*[:=]\\s*['\"]([A-Za-z0-9+/=\\n]{50,})['\"]",
    "severity": "critical"
  },
  {
    "id": "encryption_key_assignment",
    "name": "Encryption/Secret Key Assignment",
    "regex": "(?i)(?:encryption[_\\-]?key|aes[_\\-]?key|hmac[_\\-]?secret|signing[_\\-]?key)\\s*[:=]\\s*['\"]([a-zA-Z0-9_\\-=+/]{24,})['\"]",
    "severity": "critical"
  },
  {
    "id": "hardcoded_password",
    "name": "Hardcoded Password (contextual)",
    "regex": "(?i)(?:password|passwd)\\s*[:=]\\s*['\"]([^'\"\\s]{10,})['\"](?!.*placeholder|.*example|.*your)",
    "severity": "high"
  }
]
